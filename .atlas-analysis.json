  "keyFeatures": [
    "Episode 6 game service library with Item Mall, Battlefield Move, and Reward Item features",
    "Client modifications for PT 182 client with battlefield move and chat exploit fixes",
    "Database agent service with character list and name availability support",
    "Login service vulnerability patches",
    "Skill abilities support (70, 87, 35)",
    "Rune combination, Chaotic Squares, and Item Synergy systems",
    "Item ability transfer and Perfect Lapisian mechanics",
    "Revenge Mark kill tracking with visual effects",
    "Lua API for monster AI scripting",
    "Episode 6 NpcQuest format support with 6 quest results",
    "Item repair cost calculations for EP5 and EP6.4",
    "Town move scrolls and item effect handling"
  ],
